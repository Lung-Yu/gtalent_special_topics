{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "HelloworldApplication",
            "request": "launch",
            "mainClass": "com.gtalent.helloworld.HelloworldApplication",
            "cwd": "${workspaceFolder}/apps/helloworld",
            "preLaunchTask": "maven: compile helloworld",
            "classPaths": [
                "${workspaceFolder}/apps/helloworld/target/classes",
                "$MavenDependencies"
            ],
            "vmArgs": "-Dspring.profiles.active=default"
        }
    ]
}
